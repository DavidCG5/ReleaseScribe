# ReleaseScribe — Variables de entorno

# --- Base de datos ---
# URL de conexión a PostgreSQL
DATABASE_URL=jdbc:postgresql://localhost:5433/releasescribe
# Usuario de PostgreSQL
DATABASE_USER=releasescribe
# Contraseña de PostgreSQL
DATABASE_PASSWORD=releasescribe

# --- OpenAI ---
# API key de OpenAI (obligatorio para usar la IA)
OPENAI_API_KEY=sk-tu-api-key-aqui
# Modelo de OpenAI (opcional, default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# --- Backend ---
# Timeout en segundos para llamadas a OpenAI (opcional, default: 30)
OPENAI_TIMEOUT_SECONDS=30
